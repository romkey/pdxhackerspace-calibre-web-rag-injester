# Calibre library
CALIBRE_METADATA_DB=/data/calibre/metadata.db
CALIBRE_LIBRARY_ROOT=/data/calibre
CALIBRE_WEB_BASE_URL=https://calibre-web.example.com
# Optional explicit link template:
# CALIBRE_WEB_DOWNLOAD_URL_TEMPLATE=https://calibre-web.example.com/download/{book_id}/{fmt}

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=calibre_books
QDRANT_DISTANCE=cosine
VECTOR_SIZE=384

# Embeddings / chunking
# Use sentence_transformers or ollama
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Optional Hugging Face cache directory used by sentence-transformers.
# For Docker, this should be a container path, and docker-compose.yml maps it to host storage.
HF_CACHE_DIR=/hf-cache
# Optional compatibility variables; usually not needed if HF_CACHE_DIR is set.
# HF_HOME=/hf-cache
# TRANSFORMERS_CACHE=/hf-cache
# SENTENCE_TRANSFORMERS_HOME=/hf-cache
# OLLAMA_URL is used only when EMBEDDING_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_TIMEOUT_SECONDS=120
CHUNK_SIZE=1200
CHUNK_OVERLAP=120
BATCH_SIZE=64
