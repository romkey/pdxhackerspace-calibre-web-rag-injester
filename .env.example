# Calibre library
CALIBRE_METADATA_DB=/data/calibre/metadata.db
CALIBRE_LIBRARY_ROOT=/data/calibre
CALIBRE_WEB_BASE_URL=https://calibre-web.example.com
# Optional explicit link template:
# CALIBRE_WEB_DOWNLOAD_URL_TEMPLATE=https://calibre-web.example.com/download/{book_id}/{fmt}

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=calibre_books
QDRANT_DISTANCE=cosine
VECTOR_SIZE=768

# Embeddings / chunking
# Default provider is ollama. sentence_transformers is available as an optional extra:
#   pip install calibre-web2rag[sentence-transformers]
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_URL=http://ollama:11434
OLLAMA_TIMEOUT_SECONDS=120
CHUNK_SIZE=1200
CHUNK_OVERLAP=120
BATCH_SIZE=64

# Max token context length for the embedding model. Texts exceeding this
# (estimated at ~4 chars/token) are truncated before embedding.
EMBEDDING_CONTEXT_LENGTH=8192
